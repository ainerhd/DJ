<Window x:Class="AudioMixerController.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Audio Mixer Controller"
        Height="740" Width="1100"
        MinHeight="580" MinWidth="800"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource AppBg}">

    <Grid Margin="16,14,16,14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>   <!-- Header -->
            <RowDefinition Height="10"/>     <!-- Gap -->
            <RowDefinition Height="Auto"/>   <!-- Controls -->
            <RowDefinition Height="10"/>     <!-- Gap -->
            <RowDefinition Height="*"/>      <!-- Channel list -->
            <RowDefinition Height="10"/>     <!-- Gap -->
            <RowDefinition Height="Auto"/>   <!-- Status bar -->
        </Grid.RowDefinitions>

        <!-- ── Header ──────────────────────────────────────────────────── -->
        <Border Grid.Row="0" Style="{StaticResource Card}" Padding="18,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Left: title -->
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="♪" FontSize="22" Foreground="#4A90D9" Margin="0,0,10,0"
                               VerticalAlignment="Center"/>
                    <TextBlock Text="Audio Mixer Controller" FontSize="18" FontWeight="SemiBold"
                               Foreground="#E6EDF3" VerticalAlignment="Center"/>
                    <Border Background="#1A3050" BorderBrush="#2A5080" BorderThickness="1"
                            CornerRadius="4" Margin="12,0,0,0" Padding="8,2" VerticalAlignment="Center">
                        <TextBlock Text="LIVE" FontSize="10" FontWeight="Bold"
                                   Foreground="#4A90D9"/>
                    </Border>
                </StackPanel>

                <!-- Right: status pill -->
                <Border Grid.Column="1" Background="#1C2433" BorderBrush="#30363D" BorderThickness="1"
                        CornerRadius="20" Padding="12,6" VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal">
                        <Ellipse Width="7" Height="7" VerticalAlignment="Center" Margin="0,0,6,0"
                                  Fill="{Binding ConnectionStatus, Converter={StaticResource ConnectionStatusBrush}}"/>
                        <TextBlock Text="{Binding ConnectionStatus}"
                                   Foreground="{Binding ConnectionStatus, Converter={StaticResource ConnectionStatusBrush}}"
                                   FontSize="12"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <!-- ── Controls bar ────────────────────────────────────────────── -->
        <Border Grid.Row="2" Style="{StaticResource Card}" Padding="16,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>  <!-- Port label -->
                    <ColumnDefinition Width="160"/>   <!-- Port combo -->
                    <ColumnDefinition Width="Auto"/>  <!-- Refresh -->
                    <ColumnDefinition Width="16"/>    <!-- Spacer -->
                    <ColumnDefinition Width="Auto"/>  <!-- Baud label -->
                    <ColumnDefinition Width="120"/>   <!-- Baud combo -->
                    <ColumnDefinition Width="*"/>     <!-- Flex -->
                    <ColumnDefinition Width="Auto"/>  <!-- Connect -->
                    <ColumnDefinition Width="8"/>
                    <ColumnDefinition Width="Auto"/>  <!-- Disconnect -->
                    <ColumnDefinition Width="16"/>    <!-- Divider -->
                    <ColumnDefinition Width="Auto"/>  <!-- Config -->
                </Grid.ColumnDefinitions>

                <!-- Port -->
                <StackPanel Grid.Column="0" Orientation="Vertical" VerticalAlignment="Center" Margin="0,0,8,0">
                    <TextBlock Style="{StaticResource FieldLabel}" Text="PORT" Margin="0,0,0,3"/>
                </StackPanel>
                <ComboBox Grid.Column="1" VerticalAlignment="Center"
                          ItemsSource="{Binding AvailablePorts}"
                          SelectedItem="{Binding SelectedPort}"/>
                <Button Grid.Column="2" Margin="6,0,0,0" VerticalAlignment="Center"
                        Padding="10,6" Content="↺  Refresh"
                        Command="{Binding RefreshPortsCommand}"/>

                <!-- Separator -->
                <Rectangle Grid.Column="3" Width="1" Fill="#30363D" Margin="0,4" VerticalAlignment="Stretch"/>

                <!-- Baudrate -->
                <StackPanel Grid.Column="4" Orientation="Vertical" VerticalAlignment="Center" Margin="0,0,8,0">
                    <TextBlock Style="{StaticResource FieldLabel}" Text="BAUDRATE" Margin="0,0,0,3"/>
                </StackPanel>
                <ComboBox Grid.Column="5" VerticalAlignment="Center"
                          ItemsSource="{Binding AvailableBaudRates}"
                          SelectedItem="{Binding SelectedBaudRate}"/>

                <!-- Connection buttons -->
                <Button Grid.Column="7" VerticalAlignment="Center"
                        Style="{StaticResource PrimaryButton}"
                        Padding="16,7" Content="⚡  Verbinden"
                        Command="{Binding ConnectCommand}"/>
                <Button Grid.Column="9" VerticalAlignment="Center"
                        Style="{StaticResource DangerButton}"
                        Padding="14,7" Content="✕  Trennen"
                        Command="{Binding DisconnectCommand}"/>

                <!-- Divider -->
                <Rectangle Grid.Column="10" Width="1" Fill="#30363D" Margin="0,4" VerticalAlignment="Stretch"/>

                <!-- Config -->
                <Button Grid.Column="11" VerticalAlignment="Center"
                        Padding="14,7" Content="⚙  Konfiguration"
                        Click="OpenMonitor_Click"/>
            </Grid>
        </Border>

        <!-- ── Channel list ─────────────────────────────────────────────── -->
        <Border Grid.Row="4" Style="{StaticResource Card}" Padding="16,14">
            <DockPanel>
                <!-- Section header -->
                <Grid DockPanel.Dock="Top" Margin="0,0,0,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Style="{StaticResource SectionTitle}" Text="Kanäle" Margin="0"/>
                    <TextBlock Grid.Column="1" Foreground="#6E7681" FontSize="11" VerticalAlignment="Center">
                        <Run Text="{Binding Channels.Count, Mode=OneWay}"/>
                        <Run Text=" Kanal(e) aktiv"/>
                    </TextBlock>
                </Grid>

                <DataGrid ItemsSource="{Binding Channels}"
                          AutoGenerateColumns="False"
                          IsReadOnly="True"
                          HeadersVisibility="Column"
                          GridLinesVisibility="Horizontal"
                          SelectionUnit="FullRow">
                    <DataGrid.Columns>

                        <!-- Kanal index -->
                        <DataGridTextColumn Header="KANAL"
                                            Binding="{Binding DisplayName}"
                                            Width="160">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="FontWeight"      Value="SemiBold"/>
                                    <Setter Property="Foreground"      Value="#8B949E"/>
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                    <Setter Property="Padding"         Value="10,0"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>

                        <!-- Volume bar + value -->
                        <DataGridTemplateColumn Header="LAUTSTÄRKE" Width="220" IsReadOnly="True">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Grid Margin="10,0" VerticalAlignment="Center">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="44"/>
                                        </Grid.ColumnDefinitions>
                                        <ProgressBar Minimum="0" Maximum="100"
                                                     Value="{Binding AppliedVolume, Mode=OneWay}"
                                                     Height="6" VerticalAlignment="Center"
                                                     Margin="0,0,8,0"/>
                                        <TextBlock Grid.Column="1"
                                                   Text="{Binding AppliedVolume, StringFormat={}{0:F0}%}"
                                                   Foreground="#8B949E" FontSize="12"
                                                   VerticalAlignment="Center"
                                                   HorizontalAlignment="Right"/>
                                    </Grid>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <!-- Device name -->
                        <DataGridTextColumn Header="GERÄT"
                                            Binding="{Binding TargetDeviceName}"
                                            Width="*">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                    <Setter Property="Padding"           Value="10,0"/>
                                    <Setter Property="Foreground"        Value="#E6EDF3"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>

                        <DataGridTextColumn Header="STATUS"
                                            Binding="{Binding RoutingStatus}"
                                            Width="140">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                    <Setter Property="Padding" Value="10,0"/>
                                    <Setter Property="Foreground" Value="#57D995"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>

                    </DataGrid.Columns>
                </DataGrid>
            </DockPanel>
        </Border>

        <!-- ── Status bar ──────────────────────────────────────────────── -->
        <Border Grid.Row="6" Background="#161B22" BorderBrush="#30363D" BorderThickness="1"
                CornerRadius="8" Padding="16,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" Text="Aktiver Port" Style="{StaticResource FieldLabel}"
                           Margin="0" VerticalAlignment="Center"/>
                <TextBlock Grid.Column="1" Foreground="#4A90D9" FontWeight="SemiBold" FontSize="13"
                           Text="{Binding ActivePort}" Margin="8,0,0,0" VerticalAlignment="Center"/>

                <Rectangle Grid.Column="2" Fill="Transparent"/>

                <TextBlock Grid.Column="3" Text="Status" Style="{StaticResource FieldLabel}"
                           Margin="0" VerticalAlignment="Center"/>
                <StackPanel Grid.Column="4" Orientation="Horizontal" Margin="8,0,0,0" VerticalAlignment="Center">
                    <Ellipse Width="7" Height="7"
                             Fill="{Binding ConnectionStatus, Converter={StaticResource ConnectionStatusBrush}}"
                             VerticalAlignment="Center" Margin="0,0,6,0"/>
                    <TextBlock Text="{Binding ConnectionStatus}"
                               Foreground="{Binding ConnectionStatus, Converter={StaticResource ConnectionStatusBrush}}"
                               FontWeight="SemiBold" FontSize="13"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
