<Window x:Class="AudioMixerController.App.MonitorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Mixer Konfiguration" Height="700" Width="980"
        WindowStartupLocation="CenterOwner">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
    </Window.Resources>
    <Grid Margin="12" Background="#111111">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Padding="12" CornerRadius="10" Background="#1D1D1D" Margin="0,0,0,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="180" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="100" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="100" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="130" />
                </Grid.ColumnDefinitions>

                <TextBlock Foreground="White" Text="DeadZone" VerticalAlignment="Center" />
                <TextBox Grid.Column="1" Margin="8,0,0,0" Text="{Binding DeadZone, UpdateSourceTrigger=PropertyChanged}" />

                <TextBlock Grid.Column="2" Foreground="White" Text="Buffer" Margin="12,0,0,0" VerticalAlignment="Center" />
                <TextBox Grid.Column="3" Margin="8,0,0,0" Text="{Binding BufferSize, UpdateSourceTrigger=PropertyChanged}" />

                <TextBlock Grid.Column="4" Foreground="White" Text="Smoothing" Margin="12,0,0,0" VerticalAlignment="Center" />
                <TextBox Grid.Column="5" Margin="8,0,0,0" Text="{Binding SmoothingFactor, UpdateSourceTrigger=PropertyChanged}" />

                <CheckBox Grid.Column="6" Grid.ColumnSpan="2" Margin="14,0,0,0" VerticalAlignment="Center" Foreground="White"
                          IsChecked="{Binding DebugLogsEnabled}" Content="Debug Logs anzeigen"/>
            </Grid>
        </Border>

        <Border Grid.Row="1" Padding="12" CornerRadius="10" Background="#1D1D1D" Margin="0,0,0,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="220" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <TextBlock Foreground="White" Text="Profil" VerticalAlignment="Center" />
                <ComboBox Grid.Column="1" Margin="8,0,0,0" ItemsSource="{Binding PresetNames}" SelectedItem="{Binding SelectedPresetName}" IsEditable="True" />
                <Button Grid.Column="2" Margin="8,0,0,0" Padding="12,6" Content="Laden" Command="{Binding LoadPresetCommand}" />
                <Button Grid.Column="3" Margin="8,0,0,0" Padding="12,6" Content="Speichern" Command="{Binding SavePresetCommand}" />
                <Button Grid.Column="4" Margin="8,0,0,0" Padding="12,6" Content="Geräte aktualisieren" Command="{Binding RefreshDevicesCommand}" />
                <Button Grid.Column="5" Margin="8,0,0,0" Padding="12,6" Content="Einstellungen sichern" Command="{Binding SaveSettingsCommand}" />
            </Grid>
        </Border>

        <Border Grid.Row="2" Padding="12" CornerRadius="10" Background="#161616" Margin="0,0,0,10">
            <DataGrid ItemsSource="{Binding ChannelRouting}" AutoGenerateColumns="False" CanUserAddRows="False" HeadersVisibility="Column">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Kanal" Binding="{Binding ChannelIndex}" IsReadOnly="True" Width="90" />

                    <DataGridTemplateColumn Header="Audio Gerät" Width="*">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <ComboBox ItemsSource="{Binding DataContext.AudioDevices, RelativeSource={RelativeSource AncestorType=Window}}"
                                          DisplayMemberPath="Name"
                                          SelectedValuePath="Id"
                                          SelectedValue="{Binding AudioDeviceId, UpdateSourceTrigger=PropertyChanged}" />
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <DataGridCheckBoxColumn Header="Invertieren" Binding="{Binding Invert}" Width="120" />
                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <Border Grid.Row="3" Padding="12" CornerRadius="10" Background="#1D1D1D"
                Visibility="{Binding DebugLogsEnabled, Converter={StaticResource BoolToVis}}">
            <DockPanel>
                <Button DockPanel.Dock="Top" Width="120" Margin="0,0,0,8" Padding="10,4" Content="Logs leeren" Command="{Binding ClearLogsCommand}" />
                <ListBox ItemsSource="{Binding LogLines}" />
            </DockPanel>
        </Border>
    </Grid>
</Window>
