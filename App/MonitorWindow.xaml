<Window x:Class="AudioMixerController.App.MonitorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Mixer — Konfiguration"
        Height="860" Width="1000"
        MinHeight="820" MinWidth="780"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource AppBg}">

    <Grid Margin="16,14,16,14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>   <!-- Signal filter -->
            <RowDefinition Height="10"/>
            <RowDefinition Height="Auto"/>   <!-- Preset management -->
            <RowDefinition Height="10"/>
            <RowDefinition Height="3*" MinHeight="300"/>      <!-- Channel routing -->
            <RowDefinition Height="8"/>                         <!-- Splitter -->
            <RowDefinition Height="3*" MinHeight="300"/>      <!-- Live values -->
            <RowDefinition Height="Auto"/>                      <!-- Debug splitter -->
            <RowDefinition Height="Auto"/>                      <!-- Debug logs -->
        </Grid.RowDefinitions>

        <!-- ── Signal-Filter ───────────────────────────────────────────── -->
        <Border Grid.Row="0" Style="{StaticResource Card}" Padding="16,14">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- DeadZone -->
                <StackPanel Grid.Column="0">
                    <TextBlock Style="{StaticResource FieldLabel}" Text="DEADZONE (RAW)"/>
                    <TextBox ToolTip="RAW-Randbereich, der hart auf 0% bzw. 100% geklemmt wird. Beispiel: 5 => RAW &lt;= 5 ist 0%, RAW &gt;= 1018 ist 100%."
                             Text="{Binding DeadZone, UpdateSourceTrigger=LostFocus, ValidatesOnExceptions=True, NotifyOnValidationError=True}"/>
                </StackPanel>

                <!-- Buffer -->
                <StackPanel Grid.Column="2">
                    <TextBlock Style="{StaticResource FieldLabel}" Text="BUFFER-GRÖßE"/>
                    <TextBox ToolTip="Anzahl RAW-Samples für Mittelwert. Höher = ruhiger, aber etwas träger. Empfohlen: 3 bis 6."
                             Text="{Binding BufferSize, UpdateSourceTrigger=LostFocus, ValidatesOnExceptions=True, NotifyOnValidationError=True}"/>
                </StackPanel>

                <!-- Smoothing -->
                <StackPanel Grid.Column="4">
                    <TextBlock Style="{StaticResource FieldLabel}" Text="SMOOTHING"/>
                    <TextBox ToolTip="Ramp-Faktor für Lautstärkeänderung. 1.0 = direkt, kleiner = weicher/träger. Empfohlen: 0.15 bis 0.35."
                             Text="{Binding SmoothingFactor, UpdateSourceTrigger=LostFocus, ValidatesOnExceptions=True, NotifyOnValidationError=True}"/>
                </StackPanel>

                <!-- Debug toggle -->
                <Border Grid.Column="6" Background="#1C2433" BorderBrush="#30363D" BorderThickness="1"
                        CornerRadius="8" Padding="12,8" VerticalAlignment="Bottom">
                    <StackPanel>
                        <CheckBox IsChecked="{Binding AutoReconnectEnabled}"
                                  Content="Auto-Reconnect" Margin="0,0,0,6"/>
                        <CheckBox IsChecked="{Binding DebugLogsEnabled}"
                                  Content="Debug Logs"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <!-- ── Profil-Verwaltung ────────────────────────────────────────── -->
        <Border Grid.Row="2" Style="{StaticResource Card}" Padding="16,14">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>  <!-- "Profil" label col -->
                    <ColumnDefinition Width="200"/>   <!-- Preset combo -->
                    <ColumnDefinition Width="Auto"/>  <!-- Laden -->
                    <ColumnDefinition Width="16"/>    <!-- Divider -->
                    <ColumnDefinition Width="Auto"/>  <!-- Name label -->
                    <ColumnDefinition Width="160"/>   <!-- Name input -->
                    <ColumnDefinition Width="Auto"/>  <!-- Speichern -->
                    <ColumnDefinition Width="8"/>
                    <ColumnDefinition Width="Auto"/>  <!-- Duplizieren -->
                    <ColumnDefinition Width="8"/>
                    <ColumnDefinition Width="Auto"/>  <!-- Umbenennen -->
                    <ColumnDefinition Width="8"/>
                    <ColumnDefinition Width="Auto"/>  <!-- Löschen -->
                    <ColumnDefinition Width="*"/>     <!-- Flex -->
                    <ColumnDefinition Width="Auto"/>  <!-- Geräte -->
                    <ColumnDefinition Width="8"/>
                    <ColumnDefinition Width="Auto"/>  <!-- Einstellungen -->
                </Grid.ColumnDefinitions>

                <!-- Existing preset -->
                <StackPanel Grid.Column="0" VerticalAlignment="Center" Margin="0,0,8,0">
                    <TextBlock Style="{StaticResource FieldLabel}" Text="PROFIL" Margin="0,0,0,0"/>
                </StackPanel>
                <ComboBox Grid.Column="1" VerticalAlignment="Center"
                          ItemsSource="{Binding PresetNames}"
                          SelectedItem="{Binding SelectedPresetName}"/>
                <Button Grid.Column="2" VerticalAlignment="Center" Margin="8,0,0,0"
                        Style="{StaticResource PrimaryButton}"
                        Padding="14,7" Content="↓  Laden"
                        Command="{Binding LoadPresetCommand}"/>

                <!-- Separator -->
                <Rectangle Grid.Column="3" Width="1" Fill="#30363D" Margin="0,4" VerticalAlignment="Stretch"/>

                <!-- Save new preset -->
                <TextBlock Grid.Column="4" Style="{StaticResource FieldLabel}" Text="NAME"
                           VerticalAlignment="Center" Margin="0,0,8,0"/>
                <TextBox Grid.Column="5" VerticalAlignment="Center"
                         Text="{Binding PresetNameInput, UpdateSourceTrigger=PropertyChanged}"/>
                <Button Grid.Column="6" VerticalAlignment="Center" Margin="8,0,0,0"
                        Style="{StaticResource SuccessButton}"
                        Padding="14,7" Content="↑  Speichern"
                        Command="{Binding SavePresetCommand}"/>
                <Button Grid.Column="8" VerticalAlignment="Center"
                        Padding="12,7" Content="⧉  Duplizieren"
                        Command="{Binding DuplicatePresetCommand}"/>
                <Button Grid.Column="10" VerticalAlignment="Center"
                        Padding="12,7" Content="✎  Umbenennen"
                        Command="{Binding RenamePresetCommand}"/>
                <Button Grid.Column="12" VerticalAlignment="Center"
                        Style="{StaticResource DangerButton}"
                        Padding="12,7" Content="🗑  Löschen"
                        Command="{Binding DeletePresetCommand}"/>

                <!-- Actions -->
                <Button Grid.Column="14" VerticalAlignment="Center"
                        Padding="12,7" Content="⟳  Geräte"
                        Command="{Binding RefreshDevicesCommand}"/>
                <Button Grid.Column="16" VerticalAlignment="Center"
                        Padding="12,7" Content="💾  Sichern"
                        Command="{Binding SaveSettingsCommand}"/>
            </Grid>
        </Border>

        <GridSplitter Grid.Row="5" Height="8" HorizontalAlignment="Stretch" VerticalAlignment="Center"
                      Background="#253045" ResizeDirection="Rows" ResizeBehavior="PreviousAndNext"
                      ShowsPreview="True"/>

        <!-- ── Kanalzuweisung ───────────────────────────────────────────── -->
        <Border Grid.Row="4" Style="{StaticResource Card}" Padding="16,14">
            <DockPanel>
                <TextBlock DockPanel.Dock="Top" Style="{StaticResource SectionTitle}"
                           Text="Kanalzuweisung"/>
                <DataGrid ItemsSource="{Binding ChannelRouting}"
                          AutoGenerateColumns="False"
                          CanUserAddRows="False"
                          HeadersVisibility="Column"
                          SelectionUnit="FullRow">
                    <DataGrid.Columns>

                        <DataGridTextColumn Header="KANAL"
                                            Binding="{Binding ChannelIndex}"
                                            IsReadOnly="True" Width="80">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="FontWeight"        Value="SemiBold"/>
                                    <Setter Property="Foreground"        Value="#8B949E"/>
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                    <Setter Property="Padding"           Value="10,0"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>

                        <DataGridTextColumn Header="NAME"
                                            Binding="{Binding ChannelName, UpdateSourceTrigger=PropertyChanged}"
                                            Width="170">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                    <Setter Property="Padding" Value="10,0"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                            <DataGridTextColumn.EditingElementStyle>
                                <Style TargetType="TextBox">
                                    <Setter Property="VerticalContentAlignment" Value="Center"/>
                                </Style>
                            </DataGridTextColumn.EditingElementStyle>
                        </DataGridTextColumn>

                        <DataGridCheckBoxColumn Header="AKTIV"
                                                Binding="{Binding IsEnabled}"
                                                Width="90">
                            <DataGridCheckBoxColumn.ElementStyle>
                                <Style TargetType="CheckBox">
                                    <Setter Property="HorizontalAlignment" Value="Center"/>
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                </Style>
                            </DataGridCheckBoxColumn.ElementStyle>
                            <DataGridCheckBoxColumn.EditingElementStyle>
                                <Style TargetType="CheckBox">
                                    <Setter Property="HorizontalAlignment" Value="Center"/>
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                </Style>
                            </DataGridCheckBoxColumn.EditingElementStyle>
                        </DataGridCheckBoxColumn>

                        <DataGridTemplateColumn Header="AUDIO GERÄT" Width="*">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <ComboBox Margin="4,3"
                                              ItemsSource="{Binding DataContext.AudioDevices, RelativeSource={RelativeSource AncestorType=Window}}"
                                              DisplayMemberPath="Name"
                                              SelectedValuePath="Id"
                                              SelectedValue="{Binding AudioDeviceId, UpdateSourceTrigger=PropertyChanged}"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <DataGridCheckBoxColumn Header="INVERTIEREN"
                                                Binding="{Binding Invert}"
                                                Width="120">
                            <DataGridCheckBoxColumn.ElementStyle>
                                <Style TargetType="CheckBox">
                                    <Setter Property="HorizontalAlignment" Value="Center"/>
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                </Style>
                            </DataGridCheckBoxColumn.ElementStyle>
                            <DataGridCheckBoxColumn.EditingElementStyle>
                                <Style TargetType="CheckBox">
                                    <Setter Property="HorizontalAlignment" Value="Center"/>
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                </Style>
                            </DataGridCheckBoxColumn.EditingElementStyle>
                        </DataGridCheckBoxColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </DockPanel>
        </Border>

        <!-- ── Live Werte ───────────────────────────────────────────────── -->
        <Border Grid.Row="6" Style="{StaticResource Card}" Padding="16,14">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" MinWidth="360"/>
                    <ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="270"/>
                </Grid.ColumnDefinitions>

                <DockPanel Grid.Column="0">
                    <Grid DockPanel.Dock="Top" Margin="0,0,0,12">
                        <TextBlock Style="{StaticResource SectionTitle}" Text="Live Werte" Margin="0"/>
                        <Border HorizontalAlignment="Right" Background="#1A3015" BorderBrush="#2A4820"
                                BorderThickness="1" CornerRadius="4" Padding="8,2">
                            <TextBlock Text="LIVE" FontSize="10" FontWeight="Bold" Foreground="#57D995"/>
                        </Border>
                    </Grid>

                    <DataGrid ItemsSource="{Binding Channels}"
                              AutoGenerateColumns="False"
                              IsReadOnly="True"
                              HeadersVisibility="Column"
                              SelectionUnit="FullRow">
                        <DataGrid.Columns>

                            <DataGridTextColumn Header="KANAL"
                                                Binding="{Binding ChannelIndex}"
                                                Width="80">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="FontWeight" Value="SemiBold"/>
                                        <Setter Property="Foreground" Value="#8B949E"/>
                                        <Setter Property="VerticalAlignment" Value="Center"/>
                                        <Setter Property="Padding" Value="10,0"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>

                            <DataGridTextColumn Header="ROHWERT"
                                                Binding="{Binding RawValue}"
                                                Width="100">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="#6E7681"/>
                                        <Setter Property="VerticalAlignment" Value="Center"/>
                                        <Setter Property="Padding" Value="10,0"/>
                                        <Setter Property="FontFamily" Value="Consolas"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>

                            <DataGridTemplateColumn Header="GEFILTERT (%)" Width="*" IsReadOnly="True">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Grid Margin="10,0" VerticalAlignment="Center">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="50"/>
                                            </Grid.ColumnDefinitions>
                                            <ProgressBar Minimum="0" Maximum="100"
                                                         Value="{Binding FilteredPercent, Mode=OneWay}"
                                                         Height="5" VerticalAlignment="Center"
                                                         Margin="0,0,10,0"/>
                                            <TextBlock Grid.Column="1"
                                                       Text="{Binding FilteredPercent, StringFormat={}{0:F1}%}"
                                                       Foreground="#57D995" FontSize="12"
                                                       FontFamily="Consolas"
                                                       VerticalAlignment="Center"
                                                       HorizontalAlignment="Right"/>
                                        </Grid>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                        </DataGrid.Columns>
                    </DataGrid>
                </DockPanel>

                <Border Grid.Column="2" Background="#1C2433" BorderBrush="#30363D" BorderThickness="1"
                        CornerRadius="10" Padding="14">
                    <StackPanel>
                        <TextBlock Style="{StaticResource SectionTitle}" Text="Kalibrierung" Margin="0,0,0,12"/>

                        <TextBlock Style="{StaticResource FieldLabel}" Text="KANAL"/>
                        <ComboBox Width="120" HorizontalAlignment="Left"
                                  ItemsSource="{Binding CalibrationChannels}"
                                  SelectedItem="{Binding SelectedCalibrationChannel}"/>

                        <Grid Margin="0,14,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <Border Grid.Column="0" Background="#0D1117" BorderBrush="#30363D" BorderThickness="1" CornerRadius="6" Padding="8" Margin="0,0,6,0">
                                <StackPanel>
                                    <TextBlock Style="{StaticResource FieldLabel}" Text="RAW" Margin="0,0,0,4"/>
                                    <TextBlock Text="{Binding CurrentCalibrationRawText}" Foreground="#57D995" FontFamily="Consolas" FontSize="16" FontWeight="SemiBold"/>
                                </StackPanel>
                            </Border>

                            <Border Grid.Column="1" Background="#0D1117" BorderBrush="#30363D" BorderThickness="1" CornerRadius="6" Padding="8" Margin="0,0,6,0">
                                <StackPanel>
                                    <TextBlock Style="{StaticResource FieldLabel}" Text="MIN" Margin="0,0,0,4"/>
                                    <TextBlock Text="{Binding CurrentCalibrationMinText}" Foreground="#E6EDF3" FontFamily="Consolas" FontSize="16" FontWeight="SemiBold"/>
                                </StackPanel>
                            </Border>

                            <Border Grid.Column="2" Background="#0D1117" BorderBrush="#30363D" BorderThickness="1" CornerRadius="6" Padding="8">
                                <StackPanel>
                                    <TextBlock Style="{StaticResource FieldLabel}" Text="MAX" Margin="0,0,0,4"/>
                                    <TextBlock Text="{Binding CurrentCalibrationMaxText}" Foreground="#E6EDF3" FontFamily="Consolas" FontSize="16" FontWeight="SemiBold"/>
                                </StackPanel>
                            </Border>
                        </Grid>

                        <TextBlock Margin="0,14,0,8" Foreground="#8B949E" TextWrapping="Wrap"
                                   Text="Regler ganz runter drehen und Min messen. Danach ganz hoch drehen und Max messen."/>

                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="6"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="8"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <Button Grid.Row="0" Grid.Column="0" Padding="10,6" Content="Min messen" Command="{Binding CaptureCalibrationMinCommand}"/>
                            <Button Grid.Row="0" Grid.Column="2" Padding="10,6" Content="Max messen" Command="{Binding CaptureCalibrationMaxCommand}"/>
                            <Button Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="3" Padding="10,6" Content="Reset" Command="{Binding ClearCalibrationCommand}"/>
                        </Grid>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <!-- ── Debug Logs (conditional) ────────────────────────────────── -->
        <GridSplitter Grid.Row="7" Height="8" HorizontalAlignment="Stretch" VerticalAlignment="Center"
                      Background="#253045" ResizeDirection="Rows" ResizeBehavior="PreviousAndNext"
                      ShowsPreview="True"
                      Visibility="{Binding DebugLogsEnabled, Converter={StaticResource BoolToVis}}"/>

        <Border Grid.Row="8"
                Visibility="{Binding DebugLogsEnabled, Converter={StaticResource BoolToVis}}"
                Style="{StaticResource Card}" Padding="16,14" Margin="0,0,0,0">
            <DockPanel>
                <Grid DockPanel.Dock="Top" Margin="0,0,0,10">
                    <TextBlock Style="{StaticResource SectionTitle}" Text="Debug Logs" Margin="0"/>
                    <Button HorizontalAlignment="Right" Padding="10,5"
                            Content="Leeren" Command="{Binding ClearLogsCommand}"/>
                </Grid>
                <ListBox ItemsSource="{Binding LogLines}"
                         ScrollViewer.VerticalScrollBarVisibility="Auto"
                         MaxHeight="160"/>
            </DockPanel>
        </Border>

    </Grid>
</Window>
